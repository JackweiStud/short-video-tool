# 环境配置模板
# 复制为 .env 后填写值即可
# 核心配置项（其他会自动使用默认值）

# ==================== 必须配置 ====================

# SiliconFlow API 密钥（用于语义分段，需要从 https://siliconflow.cn 获取）
LLM_API_KEY=sk-填入你的SiliconFlow密钥

# LLM 提供商（默认 siliconflow，无需修改）
LLM_PROVIDER=siliconflow

# LLM 模型（默认 deepseek-ai/DeepSeek-V3，无需修改）
LLM_MODEL=deepseek-ai/DeepSeek-V3

# LLM API 地址（默认 siliconflow，无需修改）
LLM_BASE_URL=https://api.siliconflow.cn/v1

# ==================== 视频处理 ====================

# 视频语言代码 (en=英语, zh=中文, es=西班牙语, fr=法语等)
ASR_LANGUAGE=en

# Whisper 模型大小
# tiny=最快最不准, small=快且准, medium=慢但更准, large=最慢最准
# 推荐: small（平衡速度和质量）
WHISPER_MODEL=small

# 最小剪辑时长（秒），默认: 15
MIN_CLIP_DURATION=15

# 最大剪辑时长（秒），默认: 60
MAX_CLIP_DURATION=60

# 最多生成多少个剪辑，默认: 5
MAX_CLIPS=5

# 是否启用 LLM 语义分段（根据内容自动分割章节），默认: true
# 关闭可加快处理速度
ENABLE_TOPIC_SEGMENTATION=true

# ==================== 翻译设置 ====================

# 翻译方式: auto=自动(推荐), openai=用OpenAI, googletrans=免费谷歌翻译
# 推荐使用 auto，会自动使用 SiliconFlow 翻译
TRANSLATION_BACKEND=auto

# ==================== 下载设置 ====================

# 下载视频质量: 720p, 1080p, best=最高画质, worst=最低画质
VIDEO_QUALITY=best

# ==================== 可选：本地模型 ====================

# Faster-Whisper 本地模型目录（可选，用于加速 ASR）
# 如果设为 ~/models，需要将模型文件放在 ~/models/faster-whisper-small/ 或 ~/models/faster-whisper-medium/
# 不设置则自动从网络下载模型
# FASTER_WHISPER_LOCAL_MODEL_DIR=~/models

# ==================== 使用示例 ====================

# 示例1: 快速处理（用最小模型，短剪辑）
# WHISPER_MODEL=tiny
# MIN_CLIP_DURATION=10
# MAX_CLIP_DURATION=30

# 示例2: 使用本地模型加速
# FASTER_WHISPER_LOCAL_MODEL_DIR=~/models
# WHISPER_MODEL=small

# 示例3: 关闭语义分段（加快处理）
# ENABLE_TOPIC_SEGMENTATION=false


#ASR_INITIAL_PROMPT_ENABLED=true
#ASR_INITIAL_PROMPT_TEXT=以下是普通话的对话，使用简体中文和正确的标点符号：，。！？“”——
